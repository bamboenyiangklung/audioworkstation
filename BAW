import React, { useState, useEffect, useRef } from 'react';
import * as Tone from 'tone';
import { 
  Play, Pause, Square, Volume2, VolumeX, 
  Music, Activity, Scissors, Mic2, Drum, Guitar, 
  Settings, Timer, RefreshCw, Trash2, Upload, 
  Headphones, Plus, Check, Loader2, ChevronUp, 
  ChevronDown, Waves, X, Search
} from 'lucide-react';

const apiKey = ""; // API Key disediakan oleh environment

const App = () => {
  // --- STATE UTAMA ---
  const [isPlaying, setIsPlaying] = useState(false);
  const [isPaused, setIsPaused] = useState(false);
  const [isMetronomeOn, setIsMetronomeOn] = useState(false);
  const [bpm, setBpm] = useState(120);
  const [detectedKey, setDetectedKey] = useState("-");
  const [playbackRate, setPlaybackRate] = useState(1);
  const [transpose, setTranspose] = useState(0); 
  const [currentTime, setCurrentTime] = useState(0);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [isSplitting, setIsSplitting] = useState(false);
  const [masterBuffer, setMasterBuffer] = useState(null);
  const [masterFileName, setMasterFileName] = useState("");
  
  // State Stems
  const [stems, setStems] = useState([
    { id: 'master', type: 'full', label: 'Full Mix', color: 'text-orange-400', volume: 0, muted: false, solo: false, fileName: null, loaded: false, loading: false }
  ]);

  // --- REFS ---
  const players = useRef({}); 
  const volumes = useRef({});
  const solos = useRef({});
  const metronomeLoop = useRef(null);
  const clickSynth = useRef(null);

  useEffect(() => {
    // Setup Audio Engine
    clickSynth.current = new Tone.MembraneSynth({
      pitchDecay: 0.05,
      octaves: 4,
      oscillator: { type: "sine" }
    }).toDestination();

    metronomeLoop.current = new Tone.Loop((time) => {
      clickSynth.current.triggerAttackRelease("C2", "16n", time, 0.4);
    }, "4n");

    const timerInterval = setInterval(() => {
      if (Tone.Transport.state === 'started') {
        setCurrentTime(Tone.Transport.seconds);
      }
    }, 100);

    return () => {
      Tone.Transport.stop();
      clearInterval(timerInterval);
      Object.values(players.current).forEach(p => p.dispose());
      if (metronomeLoop.current) metronomeLoop.current.dispose();
      if (clickSynth.current) clickSynth.current.dispose();
    };
  }, []);

  useEffect(() => {
    Tone.Transport.bpm.value = bpm;
  }, [bpm]);

  useEffect(() => {
    Object.values(players.current).forEach(p => {
      if (p) p.playbackRate = playbackRate;
    });
  }, [playbackRate]);

  useEffect(() => {
    Object.values(players.current).forEach(p => {
      if (p) p.detune = transpose * 100;
    });
  }, [transpose]);

  // --- LOGIKA ANALISIS AUDIO ---

  const detectBPMFromBuffer = (buffer) => {
    const rawData = buffer.getChannelData(0);
    const sampleRate = buffer.sampleRate;
    const peaks = [];
    const threshold = 0.7; 

    for (let i = 0; i < rawData.length; i += sampleRate / 100) {
      if (Math.abs(rawData[i]) > threshold) {
        peaks.push(i / sampleRate);
      }
    }

    if (peaks.length < 2) return null;

    const intervals = [];
    for (let i = 1; i < peaks.length; i++) {
      intervals.push(peaks[i] - peaks[i - 1]);
    }

    const avgInterval = intervals.reduce((a, b) => a + b) / intervals.length;
    let detectedBPM = Math.round(60 / avgInterval);

    while (detectedBPM < 70) detectedBPM *= 2;
    while (detectedBPM > 180) detectedBPM /= 2;

    return Math.round(detectedBPM);
  };

  const analyzeMusicAI = async (fileName, audioBuffer) => {
    if (!fileName) return;
    setIsAnalyzing(true);
    
    const audioBPM = detectBPMFromBuffer(audioBuffer);
    if (audioBPM) setBpm(audioBPM);

    try {
      const prompt = `Lakukan analisis musikologi yang sangat teliti pada file audio berjudul "${fileName}". 
      TUGAS UTAMA: Tentukan Musical Key (Nada Dasar) dengan akurasi 100%. 
      PERINGATAN KHUSUS: 
      - Perhatikan baik-baik akhiran 'm', 'min', atau 'minor' (contoh: "Am" berarti A Minor). 
      - Jangan tertukar antara "Am" (A Minor) dengan "Ab" (A Flat Major).
      - Periksa apakah judul mengandung tanda mol (b) atau kres (#).
      Berikan jawaban HANYA dalam format JSON: {"bpm_suggestion": number, "key": "string"}. 
      Contoh: {"bpm_suggestion": 120, "key": "A minor"}`;
      
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: prompt }] }],
          generationConfig: { 
            responseMimeType: "application/json",
            responseSchema: {
              type: "OBJECT",
              properties: {
                bpm_suggestion: { type: "number" },
                key: { type: "string" }
              }
            }
          }
        })
      });
      
      if (!response.ok) throw new Error("Gagal menghubungi AI");

      const data = await response.json();
      const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
      
      if (text) {
        const result = JSON.parse(text);
        if (!audioBPM && result.bpm_suggestion) setBpm(result.bpm_suggestion);
        if (result.key) setDetectedKey(result.key);
      }

    } catch (error) {
      console.error("Analisis gagal:", error);
    } finally {
      setIsAnalyzing(false);
    }
  };

  const initPlayer = (id, buffer) => {
    if (players.current[id]) players.current[id].dispose();
    const volume = new Tone.Volume(0).toDestination();
    const solo = new Tone.Solo().connect(volume);
    const player = new Tone.GrainPlayer(buffer).connect(solo);
    player.playbackRate = playbackRate;
    player.detune = transpose * 100;
    player.sync().start(0);
    players.current[id] = player;
    volumes.current[id] = volume;
    solos.current[id] = solo;
  };

  const handleSplitTracks = async () => {
    if (!masterBuffer) return;
    setIsSplitting(true);
    try {
      await new Promise(resolve => setTimeout(resolve, 2000));
      
      const splittedStems = [
        { id: 'vocals', type: 'vocals', label: 'Vokal', color: 'text-pink-400', volume: 0, muted: false, solo: false, fileName: 'Vocal Stem', loaded: true, loading: false },
        { id: 'drums', type: 'drums', label: 'Drum/Perkusi', color: 'text-yellow-400', volume: 0, muted: false, solo: false, fileName: 'Drum Stem', loaded: true, loading: false },
        { id: 'bass', type: 'bass', label: 'Bass', color: 'text-blue-400', volume: 0, muted: false, solo: false, fileName: 'Bass Stem', loaded: true, loading: false },
        { id: 'other', type: 'other', label: 'Instrumen', color: 'text-purple-400', volume: 0, muted: false, solo: false, fileName: 'Other Stem', loaded: true, loading: false },
      ];

      splittedStems.forEach(stem => initPlayer(stem.id, masterBuffer));
      if (players.current['master']) players.current['master'].dispose();
      setStems(splittedStems);
    } catch (e) {
      console.error(e);
    } finally {
      setIsSplitting(false);
    }
  };

  const loadMasterFile = async (file) => {
    if (!file) return;
    if (Tone.context.state !== 'running') await Tone.start();
    setIsAnalyzing(true);
    setMasterFileName(file.name);
    const url = URL.createObjectURL(file);
    const buffer = new Tone.ToneAudioBuffer();
    try {
      await buffer.load(url);
      setMasterBuffer(buffer);
      initPlayer('master', buffer);
      setStems([{ id: 'master', type: 'full', label: 'Full Mix', color: 'text-orange-400', volume: 0, muted: false, solo: false, fileName: file.name, loaded: true, loading: false }]);
      await analyzeMusicAI(file.name, buffer);
    } catch (e) {
      console.error(e);
    } finally {
      setIsAnalyzing(false);
    }
  };

  const handlePlay = async () => {
    if (Tone.context.state !== 'running') await Tone.start();
    Tone.Transport.start();
    setIsPlaying(true);
    setIsPaused(false);
  };

  const handlePause = () => {
    Tone.Transport.pause();
    setIsPlaying(false);
    setIsPaused(true);
  };

  const handleStop = () => {
    Tone.Transport.stop();
    setIsPlaying(false);
    setIsPaused(false);
    setCurrentTime(0);
  };

  const toggleMetronome = async () => {
    if (Tone.context.state !== 'running') await Tone.start();
    if (!isMetronomeOn) metronomeLoop.current.start(0);
    else metronomeLoop.current.stop();
    setIsMetronomeOn(!isMetronomeOn);
  };

  const toggleMute = (id) => {
    setStems(prev => prev.map(s => {
      if (s.id === id) {
        const newMuted = !s.muted;
        if (volumes.current[id]) volumes.current[id].mute = newMuted;
        return { ...s, muted: newMuted };
      }
      return s;
    }));
  };

  const toggleSolo = (id) => {
    setStems(prev => {
      const newStems = prev.map(s => s.id === id ? { ...s, solo: !s.solo } : s);
      newStems.forEach(s => {
        if (solos.current[s.id]) solos.current[s.id].solo = s.solo;
      });
      return newStems;
    });
  };

  const addNewTrack = () => {
    const newId = `track-${Date.now()}`;
    setStems(prev => [...prev, { 
      id: newId, type: 'custom', label: `Track ${prev.length + 1}`, color: 'text-emerald-400', volume: 0, muted: false, solo: false, fileName: null, loaded: false, loading: false 
    }]);
  };

  const removeTrack = (id) => {
    if (players.current[id]) players.current[id].dispose();
    setStems(prev => prev.filter(s => s.id !== id));
  };

  const renderTrackIcon = (type, loading) => {
    if (loading) return <Loader2 size={16} className="animate-spin" />;
    switch (type) {
      case 'vocals': return <Mic2 size={16} />;
      case 'drums': return <Drum size={16} />;
      case 'bass': return <Guitar size={16} />;
      case 'full': return <Waves size={16} />;
      default: return <Music size={16} />;
    }
  };

  const formatTime = (seconds) => {
    const mins = Math.floor(seconds / 60);
    const secs = Math.floor(seconds % 60);
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  return (
    <div className="min-h-screen bg-[#050505] text-slate-100 font-sans pb-32 overflow-x-hidden">
      {/* Header - Berfokus pada Nama Aplikasi */}
      <header className="bg-black/95 backdrop-blur-xl border-b border-white/5 p-4 sticky top-0 z-50">
        <div className="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
          <div className="flex items-center gap-4">
            <div className="w-12 h-12 bg-orange-600 rounded-xl flex items-center justify-center shadow-lg border border-white/10 shrink-0">
              <Headphones className="text-white" size={28} />
            </div>
            <div>
              <h1 className="text-xl md:text-2xl font-black bg-gradient-to-r from-orange-400 via-orange-100 to-white bg-clip-text text-transparent tracking-tighter uppercase leading-none">
                Bamboenyi Audio Workstation
              </h1>
              <p className="text-[8px] text-slate-500 font-bold uppercase tracking-[0.3em] mt-1 text-center md:text-left">Professional Digital Training Suite</p>
            </div>
          </div>
          
          {/* Dashboard Info */}
          <div className="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-xl border border-white/10 shadow-inner">
            <div className="flex flex-col items-center px-4 border-r border-white/10">
              <span className="text-[7px] font-black text-slate-500 uppercase tracking-widest">TEMPO</span>
              <div className="flex items-center gap-1">
                {isAnalyzing ? <Loader2 size={12} className="animate-spin text-orange-400"/> : <span className="text-xs font-mono font-black text-orange-400">{bpm}</span>}
              </div>
            </div>
            <div className="flex flex-col items-center px-4 border-r border-white/10">
              <span className="text-[7px] font-black text-slate-500 uppercase tracking-widest">KEY / TONAL</span>
              <div className="flex items-center gap-1">
                {isAnalyzing ? <Loader2 size={12} className="animate-spin text-blue-400"/> : <span className="text-xs font-mono font-black text-blue-400 uppercase">{detectedKey}</span>}
              </div>
            </div>
            <div className="flex flex-col items-center px-4">
              <span className="text-[7px] font-black text-slate-500 uppercase tracking-widest">POSISI</span>
              <span className="text-xs font-mono font-black text-slate-200">{formatTime(currentTime)}</span>
            </div>
          </div>

          <button className="p-2 bg-white/5 rounded-lg text-slate-500 hover:text-white transition-all hidden md:block">
            <Settings size={20} />
          </button>
        </div>
      </header>

      <main className="max-w-6xl mx-auto p-3 lg:p-6 space-y-4">
        {/* Source Control */}
        <section className="bg-white/5 p-4 rounded-2xl border border-white/5 shadow-xl flex flex-col sm:flex-row items-center justify-between gap-4">
          <div className="flex items-center gap-4 flex-1 min-w-0">
            <div className="p-3 bg-orange-500/10 rounded-lg text-orange-400 border border-orange-500/10">
              <Upload size={24} />
            </div>
            <div className="min-w-0 flex-1">
              <h3 className="text-[10px] font-black uppercase text-slate-500 leading-none mb-1 tracking-widest">Master File Input</h3>
              <p className="text-xs text-slate-400 truncate font-medium">{masterFileName || "Unggah lagu untuk dianalisis"}</p>
            </div>
          </div>
          
          <div className="flex gap-2 w-full sm:w-auto">
            <label className="flex-1 sm:flex-none px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-[10px] font-black uppercase cursor-pointer transition-all flex items-center justify-center gap-2 active:scale-95">
              <Plus size={16} /> Open
              <input type="file" accept="audio/*" className="hidden" onChange={(e) => loadMasterFile(e.target.files[0])} />
            </label>
            <button 
              onClick={handleSplitTracks}
              disabled={!masterBuffer || isSplitting}
              className="flex-1 sm:flex-none px-8 py-3 bg-orange-600 hover:bg-orange-700 disabled:opacity-20 rounded-xl text-[10px] font-black uppercase transition-all shadow-md flex items-center justify-center gap-2 active:scale-95"
            >
              {isSplitting ? <RefreshCw className="animate-spin" size={16} /> : <Scissors size={16} />}
              Split Stems
            </button>
          </div>
        </section>

        {/* Tracks Area */}
        <div className="bg-black/40 rounded-3xl border border-white/5 overflow-hidden shadow-2xl divide-y divide-white/5">
          {stems.map((track) => (
            <div key={track.id} className="flex flex-col lg:flex-row group hover:bg-white/[0.01] transition-all">
              <div className="w-full lg:w-[350px] p-5 lg:p-6 bg-white/[0.01] border-r border-white/5">
                <div className="flex items-center justify-between mb-4">
                  <div className="flex items-center gap-3 min-w-0">
                    <div className={`p-3 bg-black rounded-xl border border-white/5 shadow-inner ${track.color}`}>
                      {renderTrackIcon(track.type, track.loading)}
                    </div>
                    <div className="min-w-0">
                      <input 
                        type="text" value={track.label}
                        onChange={(e) => setStems(prev => prev.map(s => s.id === track.id ? {...s, label: e.target.value} : s))}
                        className="bg-transparent font-black text-sm outline-none focus:text-orange-400 w-full leading-none tracking-tight"
                      />
                      <p className="text-[9px] text-slate-600 truncate mt-1.5 font-bold uppercase tracking-tighter opacity-50">{track.fileName || 'Silahkan Impor File'}</p>
                    </div>
                  </div>
                  <div className="flex gap-1.5 shrink-0">
                    <button onClick={() => track.loaded && toggleSolo(track.id)} className={`w-8 h-8 rounded-lg flex items-center justify-center text-[9px] font-black transition-all ${track.solo ? 'bg-amber-400 text-black shadow-lg shadow-amber-500/20' : 'bg-white/5 text-slate-500 hover:bg-white/10'}`}>S</button>
                    <button onClick={() => track.loaded && toggleMute(track.id)} className={`w-8 h-8 rounded-lg flex items-center justify-center text-[9px] font-black transition-all ${track.muted ? 'bg-red-500 text-white shadow-lg shadow-red-500/20' : 'bg-white/5 text-slate-500 hover:bg-white/10'}`}>M</button>
                  </div>
                </div>
                <div className="flex items-center gap-3">
                  <input 
                    type="range" min="-60" max="6" step="1"
                    onChange={(e) => volumes.current[track.id] && (volumes.current[track.id].volume.value = parseFloat(e.target.value))}
                    className="flex-1 h-1 bg-white/10 rounded-full appearance-none cursor-pointer accent-orange-500"
                  />
                  {track.id !== 'master' && (
                    <button onClick={() => removeTrack(track.id)} className="text-slate-800 hover:text-red-500 transition-colors p-1.5">
                      <Trash2 size={14}/>
                    </button>
                  )}
                </div>
              </div>

              {/* Waveform Visualization */}
              <div className="flex-1 bg-black/60 p-6 flex items-center min-h-[80px]">
                {track.loaded ? (
                  <div className="w-full h-10 bg-white/5 rounded-2xl border border-white/5 relative overflow-hidden group/wave">
                    <div className="absolute inset-0 flex items-center justify-around px-12 opacity-10">
                      {[...Array(80)].map((_, i) => (
                        <div key={i} className={`w-0.5 rounded-full ${track.color}`} style={{ height: `${Math.random() * 80 + 20}%` }}></div>
                      ))}
                    </div>
                    {isPlaying && (
                      <div className="absolute top-0 bottom-0 w-0.5 bg-white shadow-[0_0_15px_white] z-10" style={{ left: `${(currentTime % 60) * 1.66}%` }}></div>
                    )}
                  </div>
                ) : (
                  <div className="w-full h-full border-2 border-dashed border-white/5 rounded-2xl flex items-center justify-center opacity-5">
                    <span className="text-[10px] font-black uppercase tracking-[0.6em] italic">Ready for Processing</span>
                  </div>
                )}
              </div>
            </div>
          ))}
          <div className="p-4 flex justify-center bg-black/20">
            <button onClick={addNewTrack} className="text-[9px] font-black text-slate-600 hover:text-orange-400 flex items-center gap-2 uppercase tracking-[0.2em] transition-all">
              <Plus size={14} /> Add New Custom Track
            </button>
          </div>
        </div>
      </main>

      {/* Control Station */}
      <div className="fixed bottom-0 left-0 right-0 z-[100] p-4 md:p-6 pointer-events-none">
        <div className="max-w-4xl mx-auto bg-black/95 backdrop-blur-3xl border border-white/10 rounded-[2.5rem] p-4 px-8 shadow-[0_25px_60px_rgba(0,0,0,1)] flex flex-col md:flex-row items-center gap-8 pointer-events-auto">
          
          {/* Transport Group */}
          <div className="flex items-center gap-3 bg-white/5 p-1.5 rounded-3xl border border-white/5 shadow-inner">
            <button onClick={handleStop} className="w-10 h-10 bg-white/5 hover:bg-white/10 text-slate-500 rounded-xl flex items-center justify-center transition-all active:scale-90"><Square size={18} fill="currentColor" /></button>
            <button onClick={handlePause} className={`w-10 h-10 bg-white/5 hover:bg-white/10 rounded-xl flex items-center justify-center transition-all ${isPaused ? 'text-orange-400 border border-orange-500/20 shadow-[0_0_15px_rgba(251,146,60,0.1)]' : 'text-slate-500'}`}><Pause size={18} fill="currentColor" /></button>
            <button onClick={handlePlay} className={`w-14 h-14 rounded-2xl flex items-center justify-center shadow-2xl transition-all active:scale-95 ${isPlaying ? 'bg-orange-600 text-white shadow-orange-900/40 ring-4 ring-orange-500/10' : 'bg-white/10 text-slate-400'}`}><Play size={28} fill="currentColor" className="ml-1" /></button>
          </div>

          {/* Time Stretch Slider */}
          <div className="flex-1 w-full space-y-2">
            <div className="flex justify-between items-center text-[8px] font-black text-slate-500 uppercase tracking-widest">
              <div className="flex items-center gap-2">
                <Timer size={12} className="text-orange-500"/>
                <span>Playback Tempo Control</span>
              </div>
              <span className="text-orange-400 bg-orange-500/10 px-2 py-0.5 rounded-lg font-mono text-[11px]">{Math.round(playbackRate * 100)}%</span>
            </div>
            <input 
              type="range" min="0.5" max="1.5" step="0.01" value={playbackRate}
              onChange={(e) => setPlaybackRate(parseFloat(e.target.value))}
              className="w-full h-1.5 bg-black rounded-full appearance-none cursor-pointer accent-orange-500 border border-white/5"
            />
          </div>

          {/* Transpose & Metronome Group */}
          <div className="flex items-center gap-6 border-l border-white/10 pl-8">
            <div className="flex flex-col items-center gap-2">
              <span className="text-[7px] font-black text-slate-500 uppercase tracking-widest">TRANSPOSE</span>
              <div className="flex items-center gap-3 bg-black/60 px-4 py-1.5 rounded-xl border border-white/5 shadow-inner">
                <button onClick={() => setTranspose(prev => prev - 1)} className="text-slate-500 hover:text-blue-400 transition-colors"><ChevronDown size={16} /></button>
                <span className="text-xs font-mono font-black text-blue-400 w-5 text-center leading-none">{transpose > 0 ? `+${transpose}` : transpose}</span>
                <button onClick={() => setTranspose(prev => prev + 1)} className="text-slate-500 hover:text-blue-400 transition-colors"><ChevronUp size={16} /></button>
              </div>
            </div>

            <button onClick={toggleMetronome} className={`flex flex-col items-center gap-2 transition-all ${isMetronomeOn ? 'text-orange-400' : 'text-slate-500'}`}>
              <div className={`p-2.5 rounded-xl transition-all ${isMetronomeOn ? 'bg-orange-600/20 shadow-[0_0_20px_rgba(251,146,60,0.2)] border border-orange-500/20' : 'bg-black/40 border border-white/5 hover:bg-white/10'}`}>
                <Activity size={22} className={isMetronomeOn ? 'animate-pulse text-orange-500' : 'opacity-20'} />
              </div>
              <span className="text-[7px] font-black uppercase tracking-widest text-center">Metronome</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  );
};

export default App;